<!DOCTYPE html>
<html>
<head>
<title>Scan & Save Deals</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
body{
font-family: Arial;
text-align:center;
background:#f5f5f5;
padding:30px;
}

.container{
background:white;
padding:25px;
border-radius:12px;
max-width:400px;
margin:auto;
box-shadow:0 0 10px rgba(0,0,0,0.1);
}

h1{
color:#222;
}

input{
width:90%;
padding:12px;
margin:10px;
border-radius:6px;
border:1px solid #ccc;
}

button{
background:#ff5722;
color:white;
border:none;
padding:14px;
width:95%;
border-radius:8px;
font-size:16px;
}

button:hover{
background:#e64a19;
}
</style>
</head>

<body>

<div class="container">

<h1>Scan & Save Deals</h1>

<p>Get local food and shop deals sent to you.</p>

<form action="https://formspree.io/f/yourformid" method="POST">

<input type="text" name="name" placeholder="Your name (optional)">

<input type="email" name="email" placeholder="Enter your email" required>

<input type="text" name="whatsapp" placeholder="WhatsApp number (optional)">

<button type="submit">Get Deals</button>

</form>

<p style="font-size:12px;">Receive occasional deals from local stores.</p>

</div>

</body>
</html>